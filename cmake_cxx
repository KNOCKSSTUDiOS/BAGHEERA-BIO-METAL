cmake_minimum_required(VERSION 3.12)
project(KnocksAppEngine VERSION 1.0.0 LANGUAGES CXX)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

include_directories(include)

set(SOURCE_FILES 
    src/main.cpp 
    src/app_core.cpp
)

add_executable(bagheera_app ${SOURCE_FILES})

# Link native OS threading and real-time processing extensions
target_link_libraries(bagheera_app pthread)
